{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "python -m enkryptai_agent_security.hooks.scripts.cursor.before_submit_prompt"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "python -m enkryptai_agent_security.hooks.scripts.cursor.before_mcp_execution"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "python -m enkryptai_agent_security.hooks.scripts.cursor.after_mcp_execution"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python -m enkryptai_agent_security.hooks.scripts.cursor.after_agent_response"
      }
    ],
    "stop": [
      {
        "command": "python -m enkryptai_agent_security.hooks.scripts.cursor.stop"
      }
    ]
  }
}
