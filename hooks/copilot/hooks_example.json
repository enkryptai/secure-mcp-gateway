{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "python -m enkrypt_security.hooks.scripts.copilot.session_start",
        "powershell": "python -m enkrypt_security.hooks.scripts.copilot.session_start",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "python -m enkrypt_security.hooks.scripts.copilot.user_prompt_submitted",
        "powershell": "python -m enkrypt_security.hooks.scripts.copilot.user_prompt_submitted",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "python -m enkrypt_security.hooks.scripts.copilot.pre_tool_use",
        "powershell": "python -m enkrypt_security.hooks.scripts.copilot.pre_tool_use",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "python -m enkrypt_security.hooks.scripts.copilot.post_tool_use",
        "powershell": "python -m enkrypt_security.hooks.scripts.copilot.post_tool_use",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "python -m enkrypt_security.hooks.scripts.copilot.session_end",
        "powershell": "python -m enkrypt_security.hooks.scripts.copilot.session_end",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "python -m enkrypt_security.hooks.scripts.copilot.error_occurred",
        "powershell": "python -m enkrypt_security.hooks.scripts.copilot.error_occurred",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
