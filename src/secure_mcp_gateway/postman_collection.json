    {
      "name": "MCP Health",
      "description": "On-demand MCP server health checks — connectivity, tool discovery, and tool execution. These APIs accept raw MCP server configuration in the request body (the server does NOT need to be pre-registered in the gateway).",
      "item": [
        {
          "name": "Server Connectivity Check",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"server_name\": \"echo_server\",\n  \"description\": \"Simple echo MCP server\",\n  \"config\": {\n    \"command\": \"python\",\n    \"args\": [\"src/secure_mcp_gateway/bad_mcps/echo_mcp.py\"],\n    \"env\": {}\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/mcp/server",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health", "mcp", "server"]
            },
            "description": "Check connectivity to an MCP server. Spawns the server process, runs session.initialize(), and returns the server's reported name, version, description, and response time.\n\nReturns HTTP 200 even if the server is unreachable — check data.connectivity.status for connected or unreachable."
          }
        },
        {
          "name": "Server Connectivity Check (Unreachable)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"server_name\": \"broken_server\",\n  \"config\": {\n    \"command\": \"python\",\n    \"args\": [\"nonexistent_script.py\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/mcp/server",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health", "mcp", "server"]
            },
            "description": "Example of an unreachable server — the command points to a nonexistent script."
          }
        },
        {
          "name": "Server Info & Tools",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"server_name\": \"echo_server\",\n  \"description\": \"Simple echo MCP server\",\n  \"config\": {\n    \"command\": \"python\",\n    \"args\": [\"src/secure_mcp_gateway/bad_mcps/echo_mcp.py\"],\n    \"env\": {}\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/mcp/server/info",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "mcp", "server", "info"]
            },
            "description": "Discover all tools exposed by an MCP server. Returns the server's metadata (name, version, description) and a list of all tools with their name, description, and inputSchema."
          }
        },
        {
          "name": "Tool Execution Check (Success)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"server_name\": \"echo_server\",\n  \"description\": \"Simple echo MCP server\",\n  \"config\": {\n    \"command\": \"python\",\n    \"args\": [\"src/secure_mcp_gateway/bad_mcps/echo_mcp.py\"],\n    \"env\": {}\n  },\n  \"tool_name\": \"echo\",\n  \"tool_args\": {\n    \"message\": \"hello from Postman\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/mcp/tool",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health", "mcp", "tool"]
            },
            "description": "Execute a specific tool on an MCP server and return the result. This calls session.call_tool() with the given arguments.\n\nReturns HTTP 200 even if the tool errors — check data.execution.status for ok or error."
          }
        },
        {
          "name": "Tool Execution Check (Nonexistent Tool)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"server_name\": \"echo_server\",\n  \"config\": {\n    \"command\": \"python\",\n    \"args\": [\"src/secure_mcp_gateway/bad_mcps/echo_mcp.py\"]\n  },\n  \"tool_name\": \"nonexistent_tool\",\n  \"tool_args\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/mcp/tool",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health", "mcp", "tool"]
            },
            "description": "Example of calling a tool that does not exist on the server."
          }
        }
      ]
    },
