    {
      "name": "Guardrails",
      "description": "Security guardrails — manage input and output policies for servers",
      "item": [
        {
          "name": "Update Input Guardrails",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy\": {\n    \"enabled\": true,\n    \"policy_name\": \"Sample Airline Guardrail\",\n    \"block\": [\"policy_violation\", \"injection_attack\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}/servers/{{server_name}}/input-guardrails",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}", "servers", "{{server_name}}", "input-guardrails"]
            },
            "description": "Update input guardrails policy for a server."
          }
        },
        {
          "name": "Update Output Guardrails",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy\": {\n    \"enabled\": true,\n    \"policy_name\": \"Sample Airline Guardrail\",\n    \"block\": [\"policy_violation\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}/servers/{{server_name}}/output-guardrails",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}", "servers", "{{server_name}}", "output-guardrails"]
            },
            "description": "Update output guardrails policy for a server."
          }
        },
        {
          "name": "Update Combined Guardrails",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input_policy\": {\n    \"enabled\": true,\n    \"policy_name\": \"Sample Airline Guardrail\",\n    \"block\": [\"policy_violation\"]\n  },\n  \"output_policy\": {\n    \"enabled\": true,\n    \"policy_name\": \"Sample Airline Guardrail\",\n    \"block\": [\"policy_violation\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}/servers/{{server_name}}/guardrails",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}", "servers", "{{server_name}}", "guardrails"]
            },
            "description": "Update both input and output guardrails for a server."
          }
        }
      ]
    },
