{
  "info": {
    "name": "Enkrypt Secure MCP Gateway API",
    "description": "REST API for managing MCP configurations, projects, users, system operations, and on-demand MCP server health checks.\n\nBase URL: http://localhost:8001\n\n## Authentication\nAll endpoints (except GET /health) require a Bearer token.\nSet the `GATEWAY_API_KEY` collection variable before use.",
    "version": "2.1.8",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8001",
      "type": "string"
    },
    {
      "key": "GATEWAY_API_KEY",
      "value": "YOUR_API_KEY_HERE",
      "type": "string"
    },
    {
      "key": "config_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "config_name",
      "value": "",
      "type": "string"
    },
    {
      "key": "project_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "project_name",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_email",
      "value": "",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "",
      "type": "string"
    },
    {
      "key": "server_name",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{GATEWAY_API_KEY}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "description": "Service health check (no auth required)",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "auth": {
              "type": "noauth"
            },
            "description": "Health check endpoint. No authentication required."
          }
        }
      ]
    },
    {
      "name": "Configurations",
      "description": "MCP configuration management — create, read, update, delete configurations",
      "item": [
        {
          "name": "List All Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs"]
            },
            "description": "List all MCP configurations."
          }
        },
        {
          "name": "Create Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"config_name\": \"my_new_config\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs"]
            },
            "description": "Create a new MCP configuration."
          }
        },
        {
          "name": "Copy Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_config\": \"{{config_id}}\",\n  \"target_config\": \"copied_config\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/copy",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "copy"]
            },
            "description": "Copy an existing configuration. source_config can be an ID or name."
          }
        },
        {
          "name": "Rename Config",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_name\": \"renamed_config\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}/rename",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}", "rename"]
            },
            "description": "Rename a configuration."
          }
        },
        {
          "name": "Get Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}"]
            },
            "description": "Get a specific configuration by ID or name."
          }
        },
        {
          "name": "Delete Config",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}"]
            },
            "description": "Delete a configuration."
          }
        },
        {
          "name": "Get Config Projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}", "projects"]
            },
            "description": "Get all projects using a specific configuration."
          }
        },
        {
          "name": "Validate Config",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}", "validate"]
            },
            "description": "Validate a configuration for correctness."
          }
        },
        {
          "name": "Export Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_file\": \"C:/Users/username/exports/my_config.json\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/{{config_id}}/export",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "{{config_id}}", "export"]
            },
            "description": "Export a configuration to a JSON file."
          }
        },
        {
          "name": "Import Config",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"config_name\": \"imported_config\",\n  \"config_data\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/import",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "import"]
            },
            "description": "Import a configuration from JSON data."
          }
        },
        {
          "name": "Search Configs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"search_term\": \"my_config\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/configs/search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "configs", "search"]
            },
            "description": "Search configurations by name."
          }
        }
      ]
    },
